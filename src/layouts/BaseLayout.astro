---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  schemaType?: 'home' | 'story' | 'programs' | 'partners' | 'support' | 'news' | 'contact';
}

const {
  title,
  description,
  ogImage = '/images/hero/hero-image.png',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://www.houstonshinefc.org');

const siteSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["SportsTeam", "Organization"],
      "@id": "https://www.houstonshinefc.org/#organization",
      "name": "Houston Shine FC",
      "alternateName": "The Houston Shine",
      "url": "https://www.houstonshinefc.org",
      "logo": "https://www.houstonshinefc.org/houston_shine_logo.png",
      "description": "The Houston Shine is an Afghan women's soccer team proudly based in Houston, Texas. Through soccer, we are developing pathways into community building and leadership that extend far beyond the pitch.",
      "sport": "Soccer",
      "location": {
        "@type": "Place",
        "name": "Houston, Texas",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Houston",
          "addressRegion": "TX",
          "addressCountry": "US"
        }
      },
      "memberOf": {
        "@type": "SportsOrganization",
        "name": "Houston Women's Soccer Association",
        "alternateName": "HWSA"
      },
      "sameAs": [
        "https://www.instagram.com/houstonshinefc"
      ]
    }
  ]
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary Meta -->
  <title>{title} | Houston Shine FC</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={`${title} | Houston Shine FC`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Houston Shine FC" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | Houston Shine FC`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" />

  <!-- Preconnect for Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
</head>
<body>
  <a href="#main-content" class="skip-nav">Skip to main content</a>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />

  <!-- Nav scroll shadow -->
  <script>
    const nav = document.querySelector('.site-nav');
    if (nav) {
      window.addEventListener('scroll', () => {
        nav.classList.toggle('scrolled', window.scrollY > 10);
      }, { passive: true });
    }
  </script>

  <!-- Scroll Reveal (Intersection Observer) -->
  <script>
    const revealItems = document.querySelectorAll('.scroll-reveal-item');
    if (revealItems.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      revealItems.forEach((el) => observer.observe(el));
    }
  </script>
</body>
</html>
