---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProgramSection from '../components/ProgramSection.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout
  title="Programs"
  description="Houston Shine FC builds pathways beyond the pitch — competitive play, coaching pipelines, leadership development, and community engagement programs in Houston, Texas."
>
  <!-- ============ PAGE HERO ============ -->
  <section class="programs-hero">
    <video class="programs-hero-video" autoplay loop muted playsinline aria-hidden="true">
      <source src="/assets/videos/programs-hero.mp4" type="video/mp4" />
    </video>
    <div class="programs-hero-overlay"></div>
    <div class="container programs-hero-content" style="max-width: 820px;">
      <p class="page-label">Programs</p>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 1.5rem;">
        Soccer is just the beginning.
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 640px;">
        The Shine is a soccer team and a network of support for girls and adult women to help them reach for their dreams.
      </p>
    </div>
  </section>

  <!-- ============ STATS BAR ============ -->
  <section class="section stats-section">
    <div class="container">
      <div class="stats-bar">

        <div class="stat-item">
          <p class="stat-number" data-count="6" data-format="{n}x">6x</p>
          <p class="stat-desc">By the age of 14, girls drop out of sport at a rate that is six times greater than boys.</p>
          <p class="stat-source"><a href="https://www.womenssportsfoundation.org/advocacy/benefits-sports-participation-girls-women/" target="_blank" rel="noopener noreferrer" class="stat-source-link">Women's Sports Foundation (2016)</a></p>
        </div>

        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat-item">
          <p class="stat-number" data-count="40" data-format="{n}%">40%</p>
          <p class="stat-desc">40% of Afghan refugees in Houston have symptoms of PTSD or depression, more than 6 times the national average.</p>
          <p class="stat-source"><a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC12436913/" target="_blank" rel="noopener noreferrer" class="stat-source-link">PubMed Central (2025)</a></p>
        </div>

        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat-item">
          <p class="stat-number" data-count="94" data-format="{n}%">94%</p>
          <p class="stat-desc">94% of women in the C-suite played sports.</p>
          <p class="stat-source"><a href="https://www.ey.com/en_nz/athlete-programs/why-a-female-athlete-should-be-your-next-leader" target="_blank" rel="noopener noreferrer" class="stat-source-link">EY / espnW Study (2014)</a></p>
        </div>

        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat-item">
          <p class="stat-number" data-count="4" data-format="1 in {n}">1 in 4</p>
          <p class="stat-desc">Girls from low-income households currently play sports, compared to nearly half of girls from higher-income families.</p>
          <p class="stat-source"><a href="https://www.womenssportsfoundation.org/press_release/new-national-report-sheds-light-on-girls-sports-participation/" target="_blank" rel="noopener noreferrer" class="stat-source-link">Women's Sports Foundation (2020)</a></p>
        </div>

      </div>
    </div>
  </section>

  <script>
    (() => {
      const DURATION = 1400; // ms
      const EASE = (t) => 1 - Math.pow(1 - t, 3); // ease-out cubic

      function animateStat(el) {
        const target = parseInt(el.dataset.count, 10);
        const format = el.dataset.format;
        const start = performance.now();

        function tick(now) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / DURATION, 1);
          const value = Math.round(EASE(progress) * target);
          el.textContent = format.replace('{n}', value);
          if (progress < 1) requestAnimationFrame(tick);
        }

        el.textContent = format.replace('{n}', '0');
        requestAnimationFrame(tick);
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateStat(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.4 });

      document.querySelectorAll('.stat-number[data-count]').forEach(el => observer.observe(el));
    })();
  </script>

  <!-- ============ WAVE DIVIDER ============ -->
  <div class="wave-divider" aria-hidden="true">
    <svg class="wave-desktop" viewBox="0 -80 1440 200" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M -20 55 C 50 -20, 150 110, 300 10 C 450 -70, 570 100, 720 25 C 870 -55, 990 110, 1140 5 C 1290 -75, 1400 90, 1460 40"
        stroke="#D4A03C"
        stroke-width="2"
        fill="none"
        stroke-linecap="round"
        opacity="0.45"
      />
    </svg>
    <svg class="wave-mobile" viewBox="0 -60 400 140" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M -10 50 C 40 -30, 120 110, 200 20 C 280 -65, 360 95, 410 40"
        stroke="#D4A03C"
        stroke-width="2"
        fill="none"
        stroke-linecap="round"
        opacity="0.45"
      />
    </svg>
  </div>

  <!-- ============ PROGRAMS ============ -->
  <div class="program-bands" style="margin-top: 2rem;">

    <div class="program-band">
      <div class="container">
        <ProgramSection
          title="Competitive Play"
          description="Playing sports helps women and girls protect their physical and mental health, develop teamwork and social skills, and build relationships and resilience to overcome trauma. Our coaches emphasize whole-player development and positive coaching to support team and individual growth. We compete in the Houston Women's Soccer Association, practice once a week, and participate in skills development clinics and local tournaments."
          image="/images/programs/competitive-play.jpg"
          reverse={true}
          rotate={-2}
        />
      </div>
    </div>

    <!-- Quote -->
    <div class="program-quote-band">
      <div class="container" style="max-width: 800px;">
        <blockquote class="pull-quote" style="border-left: 3px solid var(--color-gold); padding-left: 1.5rem; margin: 0;">
          The Shine's soccer programming fills a critical gap in the grassroots soccer ecosystem by providing access for teenage girls and young adult women.
        </blockquote>
      </div>
    </div>

    <div class="program-band">
      <div class="container">
        <ProgramSection
          title="Scholarships and Educational Support"
          description="Education is vital for our players' success on and off the field. Many of our players were too old to attend high school by the time they arrived in Houston as refugees, and had to begin working right away. Friends and family in the Shine community raised funds for scholarships to Houston City College's intensive English program, as well as vocational training."
          image="/images/programs/scholarships.jpeg"
          rotate={3}
        />
      </div>
    </div>

    <div class="program-band">
      <div class="container">
        <ProgramSection
          title="Foundational Support"
          description="Research shows that girls and women drop out of sports because of responsibilities at home, difficulty getting to practice, the stress of difficult work schedules, and a lack of financial support for league and equipment fees. Through mentor relationships and partnerships with Dynamo Dash Charities, Houston Furniture Bank, and the Afghan Student Association at University of Houston, we support Shine players in building young adult lives that include the benefits of sports."
          image="/images/programs/community-support.jpg"
          reverse={true}
          rotate={-1.5}
        />
      </div>
    </div>

    <div class="program-band">
      <div class="container">
        <ProgramSection
          title="Women's Leadership"
          description="Soccer in America – and around the world – needs more women as players, coaches, referees, officials, and in club management. One of the reasons programming for refugee girls and women is behind our male peers is because of a lack of female coaches, so we're a training ground to develop women leaders in the game. We support internships in coaching, player support, refereeing, and translation, and are developing a bench of grassroots coaches."
          image="/images/programs/womens-leadership.jpg"
          rotate={2}
        />
      </div>
    </div>

  </div>

  <!-- ============ QUOTE ============ -->
  <section class="section">
    <div class="container" style="max-width: 800px;">
      <blockquote class="pull-quote" style="border-left: 3px solid var(--color-gold); padding-left: 1.5rem; margin: 0 0 1.5rem;">
        "Because of the Houston Shine, not only I, but all of my teammates have been able to believe in our dreams again."
      </blockquote>
      <p style="font-size: 0.875rem; font-weight: 700; color: var(--color-navy); margin: 0; padding-left: 1.5rem;">
        Rabia Yaqobi, Team Captain
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .programs-hero {
    position: relative;
    background-color: var(--color-warm-white);
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .programs-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .programs-hero-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(255, 255, 255, 0.70);
    z-index: 1;
  }

  .programs-hero-content {
    position: relative;
    z-index: 2;
  }

  /* ── Program Bands ── */
  .program-bands {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .program-band {
    background: var(--color-warm-white);
    padding: 1rem 0;
    overflow: visible;
  }

  .program-quote-band {
    padding: 4rem 0;
  }

  /* ── Wave Divider ── */
  .wave-divider {
    width: 100%;
    line-height: 0;
    pointer-events: none;
  }

  .wave-desktop {
    width: 100%;
    height: 120px;
    display: block;
  }

  .wave-mobile {
    width: 100%;
    height: 120px;
    display: none;
  }

  @media (max-width: 768px) {
    .wave-desktop {
      display: none;
    }
    .wave-mobile {
      display: block;
    }
  }

  /* ── Stats Bar ── */
  .stats-section {
    padding-top: 4rem;
    padding-bottom: 1.5rem;
  }

  .stats-bar {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .stat-item {
    flex: 1;
    padding: 0 2.5rem;
  }

  .stat-item:first-child {
    padding-left: 0;
  }

  .stat-item:last-child {
    padding-right: 0;
  }

  .stat-number {
    font-size: clamp(3rem, 5.5vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: transparent;
    -webkit-text-stroke: 2px var(--color-navy);
    line-height: 1;
    margin: 0 0 0.625rem;
    text-align: center;
  }

  .stat-desc {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0 0 0.5rem;
    text-align: center;
  }

  .stat-source {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0;
    text-align: center;
  }

  .stat-source-link {
    color: inherit;
    text-decoration: none;
  }

  .stat-divider {
    width: 1px;
    align-self: stretch;
    background: rgba(11, 37, 69, 0.1);
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .stats-bar {
      flex-direction: column;
      gap: 2.5rem;
    }

    .stat-item {
      padding: 0;
    }

    .stat-divider {
      width: 100%;
      height: 1px;
      align-self: auto;
    }
  }
</style>
