---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProgramSection from '../components/ProgramSection.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout
  title="Programs"
  description="Houston Shine FC builds pathways beyond the pitch — competitive play, coaching pipelines, leadership development, and community engagement programs in Houston, Texas."
>
  <!-- ============ PAGE HERO ============ -->
  <section class="programs-hero">
    <video class="programs-hero-video" autoplay loop muted playsinline aria-hidden="true">
      <source src="/assets/videos/programs-hero.mp4" type="video/mp4" />
    </video>
    <div class="programs-hero-overlay"></div>
    <div class="container programs-hero-content" style="max-width: 820px;">
      <p class="page-label">Programs</p>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 1.5rem;">
        Beyond the pitch.
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 640px;">
        The Shine is cultivating an ecosystem with aspirations far beyond the soccer field. These are the programs actively in development.
      </p>
    </div>
  </section>

  <!-- ============ STATS BAR ============ -->
  <section class="section stats-section">
    <div class="container">
      <div class="stats-bar">

        <div class="stat-item">
          <p class="stat-number" data-count="6" data-format="{n}x">6x</p>
          <p class="stat-desc">By the age of 14, girls drop out of sport at a rate that is six times greater than boys.</p>
          <p class="stat-source"><a href="https://www.womenssportsfoundation.org/advocacy/benefits-sports-participation-girls-women/" target="_blank" rel="noopener noreferrer" class="stat-source-link">Women's Sports Foundation (2016)</a></p>
        </div>

        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat-item">
          <p class="stat-number" data-count="40" data-format="{n}%">40%</p>
          <p class="stat-desc">40.3% of Afghan refugees in Houston have symptoms of PTSD or other major depressive disorders, vs. 3.6% PTSD and 8.3% depression in the general U.S. population.</p>
          <p class="stat-source"><a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC12436913/" target="_blank" rel="noopener noreferrer" class="stat-source-link">Azizi et al., PMC (2025)</a></p>
        </div>

        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat-item">
          <p class="stat-number" data-count="94" data-format="{n}%">94%</p>
          <p class="stat-desc">94% of C-suite women played sports, 52% at the collegiate level.</p>
          <p class="stat-source"><a href="https://www.ey.com/en_nz/athlete-programs/why-a-female-athlete-should-be-your-next-leader" target="_blank" rel="noopener noreferrer" class="stat-source-link">EY / espnW Study (2014)</a></p>
        </div>

        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat-item">
          <p class="stat-number" data-count="4" data-format="1 in {n}">1 in 4</p>
          <p class="stat-desc">Girls from low-income households currently play sports, compared to nearly half of girls from higher-income families.</p>
          <p class="stat-source"><a href="https://www.womenssportsfoundation.org/press_release/new-national-report-sheds-light-on-girls-sports-participation/" target="_blank" rel="noopener noreferrer" class="stat-source-link">Women's Sports Foundation (2020)</a></p>
        </div>

      </div>
    </div>
  </section>

  <script>
    (() => {
      const DURATION = 1400; // ms
      const EASE = (t) => 1 - Math.pow(1 - t, 3); // ease-out cubic

      function animateStat(el) {
        const target = parseInt(el.dataset.count, 10);
        const format = el.dataset.format;
        const start = performance.now();

        function tick(now) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / DURATION, 1);
          const value = Math.round(EASE(progress) * target);
          el.textContent = format.replace('{n}', value);
          if (progress < 1) requestAnimationFrame(tick);
        }

        el.textContent = format.replace('{n}', '0');
        requestAnimationFrame(tick);
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateStat(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.4 });

      document.querySelectorAll('.stat-number[data-count]').forEach(el => observer.observe(el));
    })();
  </script>

  <!-- ============ WAVE DIVIDER ============ -->
  <div class="wave-divider" aria-hidden="true">
    <svg viewBox="0 -80 1440 200" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M -20 55 C 50 -20, 150 110, 300 10 C 450 -70, 570 100, 720 25 C 870 -55, 990 110, 1140 5 C 1290 -75, 1400 90, 1460 40"
        stroke="#D4A03C"
        stroke-width="2"
        fill="none"
        stroke-linecap="round"
        opacity="0.45"
      />
    </svg>
  </div>

  <!-- ============ PROGRAMS ============ -->
  <section class="section" style="padding-top: 1.5rem;">
    <div class="container">

      <ProgramSection
        title="Competitive Play"
        description="The Shine competes in the Houston Women's Soccer Association (HWSA), giving players both new to the game and those more experienced a place to connect with women from across Houston."
        image="/images/programs/competitive-play.jpg"
        reverse={true}
        rotate={-2}
      />

      <ProgramSection
        title="Leadership & Professional Development"
        description="Soccer is the entry point. The broader goal is equipping players to lead in their careers, their communities, and beyond. This includes English language classes, continued education support, workforce readiness programming, and mentorship development."
        image="/images/programs/leadership.jpeg"
        rotate={3}
      />

      <ProgramSection
        title="Community Engagement"
        description="The organization plans to expand its soccer programming into youth development programs led by the players to further encourage participation in sports by communities who are often not given the opportunity. They also participate in community events and cultural programming throughout Houston. The players aren't just recipients of community support. They're becoming community builders."
        image="/images/programs/community-engagement.jpg"
        reverse={true}
        rotate={-1.5}
      />

    </div>
  </section>

  <!-- ============ QUOTE ============ -->
  <section class="section section--alt">
    <div class="container" style="max-width: 800px;">
      <blockquote class="pull-quote" style="border-left: 3px solid var(--color-gold); padding-left: 1.5rem; margin: 0 0 1.5rem;">
        "Because of the Houston Shine, not only I, but all of my teammates have been able to believe in our dreams again."
      </blockquote>
      <p style="font-size: 0.875rem; font-weight: 700; color: var(--color-navy); margin: 0; padding-left: 1.5rem;">
        Rabia Yaqobi, Team Captain
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .programs-hero {
    position: relative;
    background-color: var(--color-warm-white);
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .programs-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .programs-hero-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(255, 255, 255, 0.70);
    z-index: 1;
  }

  .programs-hero-content {
    position: relative;
    z-index: 2;
  }

  /* ── Wave Divider ── */
  .wave-divider {
    width: 100%;
    line-height: 0;
    pointer-events: none;
  }

  .wave-divider svg {
    width: 100%;
    height: 120px;
    display: block;
  }

  /* ── Stats Bar ── */
  .stats-section {
    padding-top: 4rem;
    padding-bottom: 1.5rem;
  }

  .stats-bar {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .stat-item {
    flex: 1;
    padding: 0 2.5rem;
  }

  .stat-item:first-child {
    padding-left: 0;
  }

  .stat-item:last-child {
    padding-right: 0;
  }

  .stat-number {
    font-size: clamp(3rem, 5.5vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: transparent;
    -webkit-text-stroke: 2px var(--color-navy);
    line-height: 1;
    margin: 0 0 0.625rem;
    text-align: center;
  }

  .stat-desc {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0 0 0.5rem;
    text-align: center;
  }

  .stat-source {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0;
    text-align: center;
  }

  .stat-source-link {
    color: inherit;
    text-decoration: none;
  }

  .stat-divider {
    width: 1px;
    align-self: stretch;
    background: rgba(11, 37, 69, 0.1);
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .stats-bar {
      flex-direction: column;
      gap: 2.5rem;
    }

    .stat-item {
      padding: 0;
    }

    .stat-divider {
      width: 100%;
      height: 1px;
      align-self: auto;
    }
  }
</style>
