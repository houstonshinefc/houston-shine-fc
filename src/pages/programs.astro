---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProgramSection from '../components/ProgramSection.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout
  title="Programs"
  description="Houston Shine FC builds pathways beyond the pitch — competitive play, coaching pipelines, leadership development, and community engagement programs in Houston, Texas."
>
  <!-- ============ PAGE HERO ============ -->
  <section class="programs-hero">
    <video class="programs-hero-video" autoplay loop muted playsinline aria-hidden="true">
      <source src="/assets/videos/programs-hero.mp4" type="video/mp4" />
    </video>
    <div class="programs-hero-overlay"></div>
    <div class="container programs-hero-content" style="max-width: 820px;">
      <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-white); margin-bottom: 1rem;">
        Programs
      </p>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 1.5rem;">
        Beyond the pitch.
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 640px;">
        The Shine is cultivating an ecosystem with aspirations far beyond the soccer field. These are the programs actively in development.
      </p>
    </div>
  </section>

  <!-- ============ PROGRAMS ============ -->
  <section class="section">
    <div class="container">

      <ProgramSection
        title="Competitive Play"
        description="The Shine competes in the Houston Women's Soccer Association (HWSA), giving players both new to the game and those more experienced a place to connect with women from across Houston."
        image="/images/programs/competitive-play.jpg"
        reverse={true}
        rotate={-2}
      />

      <ProgramSection
        title="Leadership & Professional Development"
        description="Soccer is the entry point. The broader goal is equipping players to lead in their careers, their communities, and beyond. This includes English language classes, continued education support, workforce readiness programming, and mentorship development."
        image="/images/programs/leadership.jpeg"
        rotate={3}
      />

      <ProgramSection
        title="Community Engagement"
        description="The organization plans to expand its soccer programming into youth development programs led by the players to further encourage participation in sports by communities who are often not given the opportunity. They also participate in community events and cultural programming throughout Houston. The players aren't just recipients of community support. They're becoming community builders."
        image="/images/programs/community-engagement.jpg"
        reverse={true}
        rotate={-1.5}
      />

    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section style="background-color: var(--color-navy); padding: 4rem 0;">
    <div class="container" style="text-align: center;">
      <h2 style="color: var(--color-white); margin-bottom: 1rem;">Want to get involved?</h2>
      <p style="color: rgba(255,255,255,0.7); max-width: 480px; margin: 0 auto 2rem;">
        Volunteer coaching, translation, transportation, event support. There are real ways to contribute.
      </p>
      <CTAButton href="/support" variant="primary">See How to Help</CTAButton>
    </div>
  </section>
</BaseLayout>

<style>
  .programs-hero {
    position: relative;
    background-color: var(--color-warm-white);
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .programs-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .programs-hero-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(255, 255, 255, 0.70);
    z-index: 1;
  }

  .programs-hero-content {
    position: relative;
    z-index: 2;
  }
</style>
