---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StickerCutout from '../components/StickerCutout.astro';
import ScrollRevealGroup from '../components/ScrollRevealGroup.astro';
import CTAButton from '../components/CTAButton.astro';
import SectionHeader from '../components/SectionHeader.astro';

const sectionLinks = [
  { label: 'Our Story',  href: '/story',    src: '/images/general/our-story.png', alt: 'Players on the field', rotate: -3, hoverShift: '-8px, -12px' },
  { label: 'Programs',   href: '/programs', src: '/images/general/programs.png',  alt: 'Training session',     rotate: 2,  hoverShift: '6px, -10px'  },
  { label: 'Partners',   href: '/partners', src: '/images/general/partners.png',  alt: 'Community event',      rotate: -1, hoverShift: '-4px, -14px' },
  { label: 'Support',    href: '/support',  src: '/images/general/support.png',   alt: 'Team huddle',          rotate: 3,  hoverShift: '8px, -10px'  },
];

const pressLinks = [
  { name: 'Texas Monthly',     logo: '/images/press/texas-monthly-black-logo.png',    href: 'https://www.texasmonthly.com/arts-entertainment/how-fifa-left-afghan-womens-soccer-players-in-houston/', height: 69 },
  { name: 'CBS News',          logo: '/images/press/CBS_News.svg',                    href: 'https://www.cbsnews.com/news/afghan-refugees-in-the-u-s-forge-their-own-path-in-womens-soccer/', height: 44 },
  { name: 'Houston Chronicle', logo: '/images/press/Houston_Chronicle_Logo_2016.svg', href: 'https://www.houstonchronicle.com/sports/dynamo/article/afghan-womens-soccer-refugees-fifa-houston-20331543.php', height: 35 },
  { name: 'KHOU',              logo: '/images/press/khou.png',                        href: 'https://www.youtube.com/watch?v=CHHZydR64kQ', height: 35 },
  { name: 'The Athletic',      logo: '/images/press/the-athletic.png',                href: 'https://www.nytimes.com/athletic/6640594/2025/09/19/afghanistan-women-us-football-team-fifa/', height: 35 },
];
---

<BaseLayout
  title="Home"
  description="The Houston Shine is an Afghan women's soccer team proudly based in Houston, Texas. Through soccer, we are developing pathways into community building and leadership that extend far beyond the pitch."
>
  <!-- ============ HERO ============ -->
  <Hero
    heading="Creating opportunity through soccer."
    subheading="The Houston Shine is an Afghan women's soccer team proudly based in Houston, Texas. Through soccer, we are developing pathways into community building and leadership that extend far beyond the pitch."
    primaryCTA={{ label: 'Support the Shine', href: '/support' }}
    secondaryCTA={{ label: 'Our Story', href: '/story' }}
    image="/images/hero/hero-image.png"
    imageAlt="Houston Shine FC"
  />

  <!-- ============ MOBILE HERO CTAs ============ -->
  <div class="hero-mobile-ctas">
    <a href="/support" class="btn btn-primary">Support the Shine</a>
    <a href="/story" class="btn btn-outline">Our Story</a>
  </div>

  <!-- ============ PRESS STRIP ============ -->
  <div style="border-top: 1px solid rgba(11,37,69,0.07); border-bottom: 1px solid rgba(11,37,69,0.07);">
    <div class="container">
      <p style="text-align: center; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-secondary); margin-bottom: 0.375rem; padding-top: 1.5rem;">
        As seen in
      </p>
      <div class="press-strip">
        {pressLinks.map(p => (
          <a href={p.href} target="_blank" rel="noopener noreferrer" aria-label={p.name}>
            <img src={p.logo} alt={p.name} class="press-strip-logo" style={`height: ${p.height}px;`} />
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ============ STICKER NAVIGATION ============ -->
  <section class="section sticker-nav-section" aria-label="Explore the Shine Universe">
    <svg class="sticker-wave" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M -20 90 C 80 30, 180 140, 340 70 C 500 0, 600 130, 760 80 C 920 30, 1020 150, 1180 65 C 1340 -15, 1420 110, 1460 80"
        stroke="#D4A03C"
        stroke-width="2"
        fill="none"
        stroke-linecap="round"
        opacity="0.45"
      />
    </svg>
    <div class="container">
      <SectionHeader
        label="Shine Universe"
        heading="Soccer. Community. Growth."
        subheading="From competitive play to community leadership; explore, follow and become involved in what the Shine is building."
        align="center"
      />
      <ScrollRevealGroup layout="spread" class="sticker-nav-group">
        {sectionLinks.map(link => (
          <div class="sticker-nav-item scroll-reveal-item">
            <StickerCutout
              src={link.src}
              alt={link.alt}
              href={link.href}
              label={link.label}
              rotate={link.rotate}
              hoverShift={link.hoverShift}
              width={260}
            />
          </div>
        ))}
      </ScrollRevealGroup>
    </div>
  </section>

  <!-- ============ MISSION STATEMENT ============ -->
  <section class="section section--alt">
    <div class="container" style="max-width: 800px;">
      <blockquote class="pull-quote" style="border-left: 3px solid var(--color-gold); padding-left: 1.5rem; margin: 0 0 1.5rem;">
        "These strong women had to flee Afghanistan so they would not be killed for being girls playing sports. They were here, in our backyard in Harris County. To me, this is more than the game. This is about the promise that we hoped for when we, all of us, came to this country at some point."
      </blockquote>
      <p style="font-size: 0.875rem; font-weight: 700; color: var(--color-navy); margin: 0 0 2rem; padding-left: 1.5rem;">
        Leslie Briones, Harris County Precinct 4 Commissioner
      </p>
      <CTAButton href="/story" variant="outline">Read Our Story</CTAButton>
    </div>
  </section>

  <!-- ============ INSTAGRAM FEED ============ -->
  <section class="section">
    <div class="container" style="max-width: 1100px;">
      <SectionHeader
        label="Instagram"
        heading="Follow the Shine."
        align="center"
      />
      <behold-widget feed-id="K7ZxyQBj20ESVptOmmqx"></behold-widget>
      <script>
        (() => {
          const d=document,s=d.createElement("script");s.type="module";
          s.src="https://w.behold.so/widget.js";d.head.append(s);
        })();
      </script>
    </div>
  </section>

  <!-- ============ PROGRAMS PREVIEW ============ -->
  <section class="section">
    <div class="container">
      <SectionHeader
        label="What We're Building"
        heading="Beyond the pitch."
        subheading="Competitive soccer. Education and professional development. Community engagement. We're working together to build a brighter future on and off the field."
      />
      <CTAButton href="/programs" variant="outline">See All Programs</CTAButton>
    </div>
  </section>

  <!-- ============ SUPPORT CTA BAND ============ -->
  <section style="background-color: var(--color-navy); padding: 4rem 0;">
    <div class="container" style="text-align: center;">
      <h2 style="color: var(--color-white); margin-bottom: 1rem;">Ready to get behind the Shine?</h2>
      <p style="color: rgba(255,255,255,0.7); max-width: 520px; margin: 0 auto 2rem; font-size: 1.0625rem;">
        Donations, volunteer hours, and corporate partnerships all make a direct difference for these women and their community.
      </p>
      <CTAButton href="/support" variant="primary" size="lg">Support the Shine</CTAButton>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-mobile-ctas {
    display: none;
  }

  @media (max-width: 768px) {
    .hero-mobile-ctas {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      padding: 1.5rem 1.25rem;
      background: var(--color-white);
    }
  }

  .sticker-nav-section {
    position: relative;
    overflow: hidden;
  }

  .sticker-wave {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    transform: translateY(-15%);
    pointer-events: none;
    z-index: 0;
  }

  .sticker-nav-group {
    padding: 3rem 0 4rem;
    position: relative;
    z-index: 1;
  }

  .sticker-nav-item {
    position: relative;
    padding-bottom: 2.5rem;
  }
</style>
