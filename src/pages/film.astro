---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout
  title="The Film"
  description="Creative studio Untold is following the journey of the Houston Shine as they embark on their new lives in America."
>
  <!-- ============ PAGE HERO ============ -->
  <section class="film-hero">
    <video class="film-hero-video" autoplay loop muted playsinline aria-hidden="true">
      <source src="/assets/videos/film-hero.mp4" type="video/mp4" />
    </video>
    <div class="film-hero-overlay"></div>
    <div class="container film-hero-content" style="max-width: 820px;">
      <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-white); margin-bottom: 1rem;">
        The Film
      </p>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 1.5rem;">
        The Second Half
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 640px;">
        Creative studio Untold is following the journey of the Shine as they embark on their new lives in America.
      </p>
    </div>
  </section>

  <!-- ============ VIDEO EMBED ============ -->
  <section class="section">
    <div class="container" style="max-width: 960px;">
      <div class="film-embed-wrap">
        <iframe
          src="https://player.vimeo.com/video/1101261109?h=43ced58002&badge=0&autopause=0&player_id=0&app_id=58479"
          title="The Second Half — Houston Shine FC"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="section section--alt">
    <div class="container" style="max-width: 720px; text-align: center;">
      <h2 style="margin-bottom: 2rem;">Ready to get behind the Shine?</h2>
      <CTAButton href="/support" variant="primary">Support the Shine</CTAButton>
    </div>
  </section>
</BaseLayout>

<style>
  .film-hero {
    position: relative;
    background-color: var(--color-warm-white);
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .film-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .film-hero-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(255, 255, 255, 0.70);
    z-index: 1;
  }

  .film-hero-content {
    position: relative;
    z-index: 2;
  }

  .film-embed-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    background-color: var(--color-navy);
  }

  .film-embed-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>
