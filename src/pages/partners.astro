---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PartnerLogo from '../components/PartnerLogo.astro';
import CTAButton from '../components/CTAButton.astro';

const partners = [
  {
    name: 'Dynamo Dash Charities',
    description: 'The Shine practices at the Dash\'s training ground and participates in Dynamo Dash Charities\' equipment and ticket assist programs.',
    href: 'https://www.houstondash.com',
    screenshot: '/images/partners/houston-dash.png',
  },
  {
    name: 'Houston Women\'s Soccer Association',
    description: 'The team competes in the HWSA\'s 11v11 spring/fall seasons and the summer 8v8 season.',
    href: 'https://www.hwsa.net',
    screenshot: '/images/partners/hwsa.png',
  },
  {
    name: 'Harris County Precinct 4',
    description: 'Commissioner Lesley Briones\' Precinct4Forward foundation has supported the team with equipment, mental health counseling, and case management services.',
    screenshot: '/images/partners/harris-county.png',
  },
  {
    name: 'Afghan Student Association – University of Houston',
    description: 'ASA is the team\'s cultural programming partner. The ASA president, Yalda Mehri, is the Shine\'s translator.',
    screenshot: '/images/partners/uh-asa.png',
  },
  {
    name: 'Houston City College',
    description: 'Shine players are enrolled in intensive English at HCC.',
    href: 'https://www.hccs.edu',
    screenshot: '/images/partners/hcc.png',
  },
  {
    name: 'Houston Furniture Bank',
    description: 'The team is a member of the Furniture Bank to help players and their families furnish their new homes.',
    href: 'https://houstonfurniturebank.org/',
    screenshot: '/images/partners/furniture-bank.png',
  },
];
---

<BaseLayout
  title="Partners & Community"
  description="Houston Shine FC is supported by a growing network of civic, sports, and community partners — from the Houston Dash and Dynamo to Harris County Commissioner Leslie Briones."
>
  <!-- ============ PAGE HERO ============ -->
  <section class="partners-hero">
    <video class="partners-hero-video" autoplay loop muted playsinline aria-hidden="true">
      <source src="/assets/videos/partners-hero.mp4" type="video/mp4" />
    </video>
    <div class="partners-hero-overlay"></div>
    <div class="container partners-hero-content" style="max-width: 820px;">
      <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-white); margin-bottom: 1rem;">
        Partners & Community
      </p>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 1.5rem;">
        Rooted in Houston.
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 640px;">
        The Shine is part of the civic fabric of Houston and its women's soccer community.
      </p>
    </div>
  </section>

  <!-- ============ PARTNER DESCRIPTIONS ============ -->
  <section class="section">
    <div class="container">
      <SectionHeader
        label="Our Partners"
        heading="Built with Houston."
      />

      <div class="partners-detail-grid">
        {partners.map(partner => (
          <div class="partner-detail scroll-reveal-item">
            {partner.screenshot && (
              <div class="partner-logo-wrap">
                <img
                  src={partner.screenshot}
                  alt={`${partner.name} logo`}
                  class="partner-logo-img"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}
            <div class="partner-detail-body">
              <h3 style="font-size: 1.0625rem; margin-bottom: 0.5rem;">{partner.name}</h3>
              <p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.65; margin: 0 0 0.75rem;">
                {partner.description}
              </p>
              {partner.href && (
                <a
                  href={partner.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  style="font-size: 0.8125rem; font-weight: 700; color: var(--color-gold); text-decoration: none;"
                >
                  Visit site →
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PARTNER WITH US ============ -->
  <section class="section section--alt">
    <div class="container" style="max-width: 720px;">
      <SectionHeader
        label="Get Involved"
        heading="Partner with the Shine."
        subheading="We're actively building our network of organizational, corporate, and community partners. If you're aligned with what we're building, we'd like to hear from you."
      />
      <CTAButton href="mailto:houstonshinefc@pm.me" variant="outline">Send a Partnership Inquiry</CTAButton>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section style="background-color: var(--color-navy); padding: 4rem 0 2.5rem;">
    <div class="container" style="text-align: center;">
      <h2 style="color: var(--color-white); margin-bottom: 2rem;">Ready to get behind the Shine?</h2>
      <CTAButton href="/support" variant="primary">Support the Shine</CTAButton>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Partners Hero ── */
  .partners-hero {
    position: relative;
    background-color: var(--color-warm-white);
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .partners-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    z-index: 0;
  }

  .partners-hero-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(255, 255, 255, 0.70);
    z-index: 1;
  }

  .partners-hero-content {
    position: relative;
    z-index: 2;
  }

  /* ── Partner cards ── */
  .partners-detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .partner-detail {
    border-radius: var(--radius-card);
    border: 1px solid rgba(11, 37, 69, 0.08);
    background: var(--color-warm-white);
    overflow: hidden;
  }

  .partner-logo-wrap {
    width: 100%;
    aspect-ratio: 3 / 2;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: var(--color-white);
    border-bottom: 1px solid rgba(11, 37, 69, 0.06);
  }

  .partner-logo-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    opacity: 0.55;
    filter: grayscale(100%);
    transition: opacity 0.2s ease, filter 0.2s ease;
  }

  .partner-detail:hover .partner-logo-img {
    opacity: 0.85;
    filter: grayscale(0%);
    animation: logo-jiggle 0.4s ease forwards;
  }

  @keyframes logo-jiggle {
    0%   { transform: scale(1)    rotate(0deg); }
    20%  { transform: scale(1.08) rotate(-3deg); }
    45%  { transform: scale(1.08) rotate(3deg); }
    65%  { transform: scale(1.08) rotate(-1.5deg); }
    80%  { transform: scale(1.08) rotate(1deg); }
    100% { transform: scale(1.06) rotate(0deg); }
  }

  .partner-detail-body {
    padding: 1.75rem;
  }
</style>
