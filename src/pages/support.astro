---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTAButton from '../components/CTAButton.astro';

// TODO: Replace # hrefs with actual donation/wishlist/impact report URLs
---

<BaseLayout
  title="Support"
  description="Support Houston Shine FC through donations, volunteering, corporate sponsorship, or your Amazon wishlist. Every contribution keeps these athletes on the pitch and in the community."
>
  <!-- ============ PAGE HERO ============ -->
  <section class="support-hero">
    <video class="support-hero-video" autoplay loop muted playsinline aria-hidden="true">
      <source src="/assets/videos/support-hero.mp4" type="video/mp4" />
    </video>
    <div class="support-hero-overlay"></div>
    <div class="container support-hero-content" style="max-width: 820px;">
      <p class="page-label">Support</p>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 1.5rem;">
        Get behind the Shine.
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 640px;">
        The Shine is powered by people and organizations in our community. Join us!
      </p>
    </div>
  </section>

  <!-- ============ SEGMENTED CTAs ============ -->
  <section class="section">
    <div class="container">
      <div class="support-layout">

        <!-- Individuals — left -->
        <div class="support-card">
          <p class="support-label">For Individuals</p>
          <h2 class="support-heading">Make a Donation</h2>
          <script src="https://donorbox.org/widget.js" paypalExpress="false"></script>
          <iframe src="https://donorbox.org/embed/houston-shine-fc?" name="donorbox" allowpaymentrequest="allowpaymentrequest" seamless="seamless" frameborder="0" scrolling="no" height="900px" width="100%" style="max-width: 500px; min-width: 250px; max-height:none!important" allow="payment"></iframe>
        </div>

        <!-- Right column — corporate + volunteer stacked -->
        <div class="support-right">

          <!-- Corporate -->
          <div class="support-card">
            <p class="support-label">For Corporate Partners</p>
            <h2 class="support-heading">Sponsor the team</h2>
            <CTAButton href="mailto:houstonshinefc@pm.me" variant="outline">
              Contact Us
            </CTAButton>
          </div>

          <!-- Wishlist -->
          <div class="support-card">
            <p class="support-label">Amazon Wishlist</p>
            <h2 class="support-heading">Send something directly</h2>
            <CTAButton href="https://www.amazon.com/registries/gl/guest-view/10ZP8VM9R9DC2?ref_=cm_sw_r_mwn_ggr-subnav-share_VRDS4YB0YZEB2BHDJ35B&language=en-US&utm_source=ig&utm_medium=social&utm_content=link_in_bio&fbclid=PAZXh0bgNhZW0CMTEAc3J0YwZhcHBfaWQMMjU2MjgxMDQwNTU4AAGnf7XwyCxXlKXGFI6jOKuaUuXtUgv72HKFEqFjl-BdvZvskKaL1Scilbcf-Co_aem_8XMPAv229dqMimdpiqRYrA" variant="outline" external={true}>View the Wishlist</CTAButton>
          </div>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .support-hero {
    position: relative;
    background-color: var(--color-warm-white);
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .support-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .support-hero-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(255, 255, 255, 0.70);
    z-index: 1;
  }

  .support-hero-content {
    position: relative;
    z-index: 2;
  }

  .support-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .support-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .support-layout {
      grid-template-columns: 1fr;
    }
  }

  .support-card {
    padding: 2rem;
    border-radius: var(--radius-card);
    border: 1px solid rgba(11, 37, 69, 0.08);
    background: var(--color-warm-white);
  }

  .support-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.5rem;
  }

  .support-heading {
    font-size: 1.375rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
</style>
