---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTAButton from '../components/CTAButton.astro';

// TODO: Replace # hrefs with actual donation/wishlist/impact report URLs
---

<BaseLayout
  title="Support"
  description="Support Houston Shine FC through donations, volunteering, corporate sponsorship, or your Amazon wishlist. Every contribution keeps these athletes on the pitch and in the community."
>
  <!-- ============ PAGE HERO ============ -->
  <section class="support-hero">
    <video class="support-hero-video" autoplay loop muted playsinline aria-hidden="true">
      <source src="/assets/videos/support-hero.mp4" type="video/mp4" />
    </video>
    <div class="support-hero-overlay"></div>
    <div class="container support-hero-content" style="max-width: 820px;">
      <p class="page-label">Support</p>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 1.5rem;">
        Get behind the Shine.
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 640px;">
        The Shine is powered by people and organizations in our community. Join us!
      </p>
    </div>
  </section>

  <!-- ============ IMPACT GRID ============ -->
  <section class="section" style="padding-top: 3.5rem; padding-bottom: 2.75rem;">
    <div class="container">
<div class="impact-grid">

        <div class="impact-item">
          <a href="https://donorbox.org/houston-shine-fc?amount=25" class="impact-circle dbox-donation-button">
            <p class="impact-amount">$25</p>
            <p class="impact-desc">Snacks & refreshments</p>
          </a>
        </div>

        <div class="impact-item">
          <a href="https://donorbox.org/houston-shine-fc?amount=50" class="impact-circle dbox-donation-button">
            <p class="impact-amount">$50</p>
            <p class="impact-desc">One pair of cleats</p>
          </a>
        </div>

        <div class="impact-item">
          <a href="https://donorbox.org/houston-shine-fc?amount=100" class="impact-circle dbox-donation-button">
            <p class="impact-amount">$100</p>
            <p class="impact-desc">One uniform kit</p>
          </a>
        </div>

        <div class="impact-item">
          <a href="https://donorbox.org/houston-shine-fc?amount=250" class="impact-circle dbox-donation-button">
            <p class="impact-amount">$250</p>
            <p class="impact-desc">Year of wifi <span style="white-space: nowrap;">(via Compudopt)</span></p>
          </a>
        </div>

        <div class="impact-item">
          <a href="https://donorbox.org/houston-shine-fc?amount=600" class="impact-circle dbox-donation-button">
            <p class="impact-amount">$600</p>
            <p class="impact-desc">One semester of English</p>
          </a>
        </div>

        <div class="impact-item">
          <a href="https://donorbox.org/houston-shine-fc?amount=2500" class="impact-circle dbox-donation-button">
            <p class="impact-amount">$2,500</p>
            <p class="impact-desc">League registration</p>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ============ SEGMENTED CTAs ============ -->
  <section class="section" style="padding-top: 0.75rem;">
    <div class="container">
      <div class="support-layout">

        <!-- Individuals — left -->
        <div class="support-card">
          <p class="support-label">For Individuals</p>
          <h2 class="support-heading">Make a Donation</h2>
          <iframe src="https://donorbox.org/embed/houston-shine-fc?" name="donorbox" allowpaymentrequest="allowpaymentrequest" seamless="seamless" frameborder="0" scrolling="no" height="900px" width="100%" style="min-width: 250px; max-height:none!important; display: block;" allow="payment"></iframe>
        </div>

        <!-- Right column — corporate + wishlist + 100% stacked -->
        <div class="support-right">

          <!-- Corporate -->
          <div class="support-card">
            <p class="support-label">For Corporate Partners</p>
            <h2 class="support-heading">Sponsor the team</h2>
            <CTAButton href="mailto:houstonshinefc@pm.me" variant="outline">
              Contact Us
            </CTAButton>
          </div>

          <!-- Wishlist -->
          <div class="support-card">
            <p class="support-label">Amazon Wishlist</p>
            <h2 class="support-heading">Send something directly</h2>
            <CTAButton href="https://www.amazon.com/registries/gl/guest-view/10ZP8VM9R9DC2?ref_=cm_sw_r_mwn_ggr-subnav-share_VRDS4YB0YZEB2BHDJ35B&language=en-US&utm_source=ig&utm_medium=social&utm_content=link_in_bio&fbclid=PAZXh0bgNhZW0CMTEAc3J0YwZhcHBfaWQMMjU2MjgxMDQwNTU4AAGnf7XwyCxXlKXGFI6jOKuaUuXtUgv72HKFEqFjl-BdvZvskKaL1Scilbcf-Co_aem_8XMPAv229dqMimdpiqRYrA" variant="outline" external={true}>View the Wishlist</CTAButton>
          </div>

          <!-- 100% card -->
          <div class="support-card hundred-card">
            <div class="hundred-band">
              <div class="hundred-graphic" aria-hidden="true">
                <p class="hundred-number" data-count="100" data-format="{n}%">100%</p>
              </div>
              <p class="hundred-text">
                Thanks to the generous support of our community who fund our operational expenses and volunteer their time, <strong>100% of your donation</strong> directly funds the effort to improve the Shine players' lives on and off the field.
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

<script is:inline>
  window.addEventListener('message', function(e) {
    if (e.origin !== 'https://donorbox.org') return;
    const embed = document.querySelector('iframe[name="donorbox"]:not(#donor-modal-iframe)');
    if (!embed) return;
    const data = e.data;
    // DonorBox sends height as a plain number string or as an object
    const height = typeof data === 'object' ? (data.height || data.scrollHeight) : parseInt(data, 10);
    if (height && height > 100) {
      embed.style.height = height + 'px';
    }
  });
</script>

<!-- ============ DONOR MODAL ============ -->
<div id="donor-modal" class="donor-modal" hidden>
  <div class="donor-modal-backdrop" id="donor-modal-backdrop"></div>
  <div class="donor-modal-content">
    <button class="donor-modal-close" id="donor-modal-close" aria-label="Close">&#x2715;</button>
    <div class="donor-modal-iframe-wrap">
      <iframe id="donor-modal-iframe" src="" name="donorbox" allowpaymentrequest="allowpaymentrequest" seamless="seamless" scrolling="yes" allow="payment"></iframe>
    </div>
  </div>
</div>

<script>
  (() => {
    const modal = document.getElementById('donor-modal');
    const iframe = document.getElementById('donor-modal-iframe');
    const closeBtn = document.getElementById('donor-modal-close');
    const backdrop = document.getElementById('donor-modal-backdrop');

    function openModal(url) {
      iframe.src = url;
      modal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.setAttribute('hidden', '');
      iframe.src = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.dbox-donation-button').forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault();
        openModal(link.href);
      });
    });

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeModal();
    });
  })();
</script>

<script>
  (() => {
    const DURATION = 1400;
    const EASE = (t) => 1 - Math.pow(1 - t, 3);

    function animateStat(el) {
      const target = parseInt(el.dataset.count, 10);
      const format = el.dataset.format;
      const start = performance.now();

      function tick(now) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / DURATION, 1);
        const value = Math.round(EASE(progress) * target);
        el.textContent = format.replace('{n}', value);
        if (progress < 1) requestAnimationFrame(tick);
      }

      el.textContent = format.replace('{n}', '0');
      requestAnimationFrame(tick);
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateStat(entry.target);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    document.querySelectorAll('.hundred-number[data-count]').forEach(el => observer.observe(el));
  })();
</script>

</BaseLayout>

<style>
  .support-hero {
    position: relative;
    background-color: var(--color-warm-white);
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .support-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .support-hero-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(255, 255, 255, 0.70);
    z-index: 1;
  }

  .support-hero-content {
    position: relative;
    z-index: 2;
  }

  .support-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: stretch;
  }

  .support-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hundred-card {
    flex: 1;
    display: flex;
    align-items: center;
  }

  @media (max-width: 768px) {
    .support-layout {
      grid-template-columns: 1fr;
    }
  }

  .support-card {
    padding: 2rem;
    border-radius: var(--radius-card);
    border: 1px solid rgba(11, 37, 69, 0.08);
    background: var(--color-warm-white);
  }

  /* ── Impact Grid ── */
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 2rem 1rem;
  }

  .impact-item {
    display: flex;
  }

  .impact-circle {
    position: relative;
    aspect-ratio: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 20%;
    gap: 0.375rem;
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  .impact-circle::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('/images/general/soccer-logo.png') center / contain no-repeat;
    filter: brightness(0) invert(1) sepia(8%) brightness(97%);
    z-index: 0;
  }

  .impact-circle > p {
    position: relative;
    z-index: 1;
  }

  .impact-circle:hover {
    animation: ball-bounce 1.0s ease forwards;
  }

  .impact-circle:hover::before {
    animation: ball-spin 1.0s ease-in-out;
  }

  @keyframes ball-bounce {
    0%   { transform: translateY(0) scale(1.05); }
    12%  { transform: translateY(-6px) scale(1.05); }
    22%  { transform: translateY(0) scale(1.05); }
    40%  { transform: translateY(-14px) scale(1.05); }
    55%  { transform: translateY(0) scale(1.05); }
    70%  { transform: translateY(-5px) scale(1.05); }
    85%  { transform: translateY(0) scale(1.05); }
    100% { transform: translateY(0) scale(1.05); }
  }

  @keyframes ball-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .impact-amount {
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-gold);
    margin: 0;
    line-height: 1;
  }

  .impact-desc {
    font-size: clamp(0.6rem, 0.9vw, 0.75rem);
    font-weight: 600;
    color: var(--color-navy);
    line-height: 1.3;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }


  @media (max-width: 768px) {
    .impact-grid {
      grid-template-columns: repeat(3, minmax(0, 110px));
      justify-content: center;
      gap: 1rem 0.75rem;
      padding: 0;
    }
  }

  /* ── 100% Band ── */
  .hundred-band {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .hundred-graphic {
    flex-shrink: 0;
  }

  .hundred-number {
    font-size: clamp(3rem, 5.5vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: transparent;
    -webkit-text-stroke: 2px var(--color-navy);
    line-height: 1;
    margin: 0;
  }

  .hundred-text {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .hundred-text strong {
    color: var(--color-navy);
    font-weight: 700;
  }


  /* ── Support Cards ── */
  .support-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.5rem;
  }

  .support-heading {
    font-size: 1.375rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  /* ── Donor Modal ── */
  .donor-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .donor-modal[hidden] {
    display: none;
  }

  .donor-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(11, 37, 69, 0.6);
    cursor: pointer;
  }

  .donor-modal-content {
    position: relative;
    background: var(--color-white);
    border-radius: var(--radius-card);
    width: 100%;
    max-width: 400px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
  }

  .donor-modal-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 1;
    background: var(--color-warm-white);
    border: none;
    border-radius: 50%;
    width: 2rem;
    height: 2rem;
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    color: var(--color-navy);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .donor-modal-iframe-wrap {
    overflow: hidden;
    flex: 1;
    border-radius: var(--radius-card);
  }

  .donor-modal-content iframe {
    width: 100%;
    border: none;
    height: 680px;
    margin-top: -72px;
  }
</style>
