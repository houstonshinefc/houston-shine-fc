---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTAButton from '../components/CTAButton.astro';

// TODO: Replace # hrefs with actual donation/wishlist/impact report URLs
---

<BaseLayout
  title="Support"
  description="Support Houston Shine FC through donations, volunteering, corporate sponsorship, or your Amazon wishlist. Every contribution keeps these athletes on the pitch and in the community."
>
  <!-- ============ PAGE HERO ============ -->
  <section style="background-color: var(--color-warm-white); padding: 5rem 0 4rem;">
    <div class="container" style="max-width: 820px;">
      <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-gold); margin-bottom: 1rem;">
        Support
      </p>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 1.5rem;">
        Get behind the Shine.
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 640px;">
        The Shine runs on community support. Whether you're an individual, a foundation, or a company — there's a way to be part of this.
      </p>
    </div>
  </section>

  <!-- ============ SEGMENTED CTAs ============ -->
  <section class="section">
    <div class="container">
      <div class="support-grid">

        <!-- Individuals -->
        <div class="support-card">
          <p class="support-label">For Individuals</p>
          <h2 class="support-heading">Make a Donation</h2>
          <p style="color: var(--color-text-secondary); font-size: 0.9375rem; line-height: 1.65; margin-bottom: 2rem;">
            Donations go directly to player support, equipment, travel, league fees, and community programming. Every dollar keeps the Shine on the field.
          </p>
          <CTAButton href="#" variant="primary" size="lg" external={true}>
            Donate Now
          </CTAButton>
        </div>

        <!-- Foundations / Nonprofits -->
        <div class="support-card">
          <p class="support-label">For Foundations & Nonprofits</p>
          <h2 class="support-heading">Request Our Impact Report</h2>
          <p style="color: var(--color-text-secondary); font-size: 0.9375rem; line-height: 1.65; margin-bottom: 2rem;">
            We're building our formal impact documentation. If you're a foundation or institutional funder interested in the Shine's work, reach out and we'll share what we have.
          </p>
          <CTAButton href="/contact?type=foundation" variant="outline">
            Request Impact Report
          </CTAButton>
        </div>

        <!-- Corporate -->
        <div class="support-card">
          <p class="support-label">For Corporate Partners</p>
          <h2 class="support-heading">Explore Sponsorship</h2>
          <p style="color: var(--color-text-secondary); font-size: 0.9375rem; line-height: 1.65; margin-bottom: 2rem;">
            Corporate partnerships power the Shine's infrastructure — from team kits to field access to community events. Let's talk about what a partnership looks like for your organization.
          </p>
          <CTAButton href="/contact?type=sponsorship" variant="outline">
            Contact Us
          </CTAButton>
        </div>

      </div>
    </div>
  </section>

  <!-- ============ VOLUNTEER ============ -->
  <section class="section section--alt">
    <div class="container" style="max-width: 720px;">
      <SectionHeader
        label="Volunteer"
        heading="Show up. We need people."
        subheading="Volunteer needs shift with the season, but here's what's typically needed:"
      />
      <ul style="list-style: none; padding: 0; margin: 0 0 2.5rem; display: flex; flex-direction: column; gap: 0.75rem;">
        {[
          'Coaching and training support',
          'Translation and interpretation (Dari/Pashto)',
          'Transportation to matches and events',
          'Event coordination and logistics',
          'Photography and media support',
        ].map(item => (
          <li style="display: flex; align-items: flex-start; gap: 0.75rem; font-size: 0.9375rem; color: var(--color-text-secondary);">
            <span style="color: var(--color-gold); font-size: 1rem; flex-shrink: 0; margin-top: 1px;">→</span>
            {item}
          </li>
        ))}
      </ul>
      <CTAButton href="/contact?type=volunteer" variant="outline">Volunteer Inquiry</CTAButton>
    </div>
  </section>

  <!-- ============ WISHLIST ============ -->
  <section class="section">
    <div class="container" style="max-width: 720px;">
      <SectionHeader
        label="Amazon Wishlist"
        heading="Send something directly."
        subheading="Equipment, gear, supplies — browse the Shine's wishlist and send something directly to the team."
      />
      <CTAButton href="#" variant="outline" external={true}>View the Wishlist</CTAButton>
    </div>
  </section>
</BaseLayout>

<style>
  .support-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .support-card {
    padding: 2rem;
    border-radius: var(--radius-card);
    border: 1px solid rgba(11, 37, 69, 0.08);
    background: var(--color-white);
  }

  .support-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.5rem;
  }

  .support-heading {
    font-size: 1.375rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
</style>
