---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PressCard from '../components/PressCard.astro';
import CTAButton from '../components/CTAButton.astro';

// Press coverage — add new items at the top (reverse chronological)
// Replace href values with real article URLs
const pressItems = [
  {
    publication: 'KHOU',
    logo: '/images/press/khou.png',
    headline: 'Afghan women\'s soccer team holds first U.S. practice in Houston after fleeing from the Taliban',
    date: '2025-05-18',
    excerpt: '',
    url: 'https://www.youtube.com/watch?v=CHHZydR64kQ',
  },
  {
    publication: 'Houston Chronicle',
    logo: '/images/press/Houston_Chronicle_Logo_2016.svg',
    headline: 'These Afghan women\'s soccer players fled the Taliban. They found a home in Houston.',
    date: '2025-05-19',
    excerpt: 'By Danielle Lerner, photography by Elizabeth Conley.',
    url: 'https://www.houstonchronicle.com/sports/dynamo/article/afghan-womens-soccer-refugees-fifa-houston-20331543.php',
  },
  {
    publication: 'The Athletic',
    logo: '/images/press/the-athletic.png',
    headline: 'U.S.-based Afghan refugees denied access to new Afghanistan women\'s soccer team',
    date: '2025-09-19',
    excerpt: 'By Colin Millar.',
    url: 'https://www.nytimes.com/athletic/6640594/2025/09/19/afghanistan-women-us-football-team-fifa/',
  },
  {
    publication: 'CBS News',
    logo: '/images/press/CBS_News.svg',
    headline: 'Afghan refugees in the U.S. forge their own path on the soccer pitch',
    date: '2025-12-06',
    excerpt: '',
    url: 'https://www.cbsnews.com/news/afghan-refugees-in-the-u-s-forge-their-own-path-in-womens-soccer/',
  },
  {
    publication: 'Texas Monthly',
    logo: '/images/press/texas-monthly-black-logo.png',
    headline: 'The Taliban Targeted Them. FIFA Saved Them. Houston Welcomed Them. Then They Were Left Behind.',
    date: '2026-03-01',
    excerpt: 'By Dion Nissenbaum, photography by Christopher Lee.',
    url: 'https://www.texasmonthly.com/arts-entertainment/how-fifa-left-afghan-womens-soccer-players-in-houston/',
  },
];
---

<BaseLayout
  title="News & Press"
  description="Media coverage and team updates from Houston Shine FC — as seen in Texas Monthly, CBS News, Houston Chronicle, and KHOU."
>
  <!-- ============ PAGE HERO ============ -->
  <section style="background-color: var(--color-warm-white); padding: 5rem 0 4rem;">
    <div class="container" style="max-width: 820px;">
      <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-gold); margin-bottom: 1rem;">
        News & Press
      </p>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 1.5rem;">
        The Shine in the news.
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 640px;">
        Coverage from Texas Monthly, CBS News, The Athletic, and more.
      </p>
    </div>
  </section>

  <!-- ============ PRESS GRID ============ -->
  <section class="section">
    <div class="container">
      <div class="press-grid">
        {pressItems.map(item => (
          <PressCard
            publication={item.publication}
            headline={item.headline}
            date={item.date}
            excerpt={item.excerpt}
            url={item.url}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============ MEDIA CONTACT ============ -->
  <section class="section section--alt">
    <div class="container" style="max-width: 680px;">
      <SectionHeader
        label="Media"
        heading="Press inquiries."
        subheading="Journalists and media professionals, we're happy to arrange interviews, provide background, or connect you with players and staff."
      />
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <CTAButton href="/contact?type=media" variant="outline">Media Inquiry</CTAButton>
        <!-- TODO: Add press kit download link when available -->
        <!-- <CTAButton href="/press-kit.zip" variant="outline" external={true}>Download Press Kit</CTAButton> -->
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .press-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
</style>
