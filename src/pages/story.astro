---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Timeline from '../components/Timeline.astro';
import PlayerCard from '../components/PlayerCard.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import CTAButton from '../components/CTAButton.astro';

// Timeline data — update dates, titles, and descriptions as the story develops
const milestones = [
  {
    date: '2007–2021',
    title: 'Afghan Women\'s National Football Team',
    description: 'Beginning in 2007, Afghanistan establishes a national football program that provides an avenue into sports for women and girls. In 2010, the team plays its first official FIFA sanctioned match, resulting in the expansion of its program, including youth development. In the years that followed, women now on the Houston Shine begin their journey into the sport.',
    media: '/images/timeline/01-establishment.png',
  },
  {
    date: 'July and August 2021',
    title: 'Taliban takeover of Afghanistan',
    description: 'The Taliban seizes control of Afghanistan and outlaws women\'s sports. By August, there are reports of women athletes being executed.',
    media: '/images/timeline/02-takeover.mp4',
    credit: 'PBS News Hour | The Fall of Afghanistan | August 16, 2021',
  },
  {
    date: 'August–October 2021',
    title: 'Female athletes evacuated',
    description: 'The international human rights and soccer communities organize multiple evacuation flights for women athletes, officials, and coaches. The first two flights include players and their families who are quickly resettled in Europe and Australia. The third flight, which departs amidst increased chaos, includes players and officials from the Afghan Football Federation, without a certain resettlement destination. The group is temporarily housed in Albania for 20 months.',
    media: '/images/timeline/03-evacuation.mp4',
    credit: 'Ayenda, directed by Marie Margolius | MSNBC | 2023',
  },
  {
    date: 'Summer 2023',
    title: 'Resettlement in Houston',
    description: 'Approximately twenty players are resettled in the U.S., with half of the group coming to Houston together. Shortly after, they\'re celebrated at a ceremony marking the first convening of the 2026 World Cup host cities focused on human rights. Without their parents for support, the players begin their lives in America. They get jobs and apartments, while also supporting their families back home. They don\'t have access to soccer.',
  },
  {
    date: 'April 2025',
    title: 'Connection',
    description: 'A chance invitation to a Houston Dash game ignites a plan to organize a practice for the Houston players.',
    media: '/images/timeline/05-connection.jpg',
  },
  {
    date: 'May 9, 2025',
    title: 'Afghan Women\'s Refugee Team',
    description: 'FIFA approves the creation of the Afghan Women\'s Refugee Team. FIFA makes plans to hold talent ID camps for resettled players across the globe for a chance to try out for the team, called Afghan Women United, but the U.S. camp would later be indefinitely postponed.',
  },
  {
    date: 'May 18, 2025',
    title: 'Houston Shine FC',
    description: 'After nearly two years of being off the pitch, community volunteers and Harris County Commissioner Lesley Briones organize a first practice. That evening, the group decides to form Houston Shine FC, representing hope and the promise of a new beginning. The team includes women from the local Afghan community, including teenagers who are playing sports for the first time.',
    media: '/images/timeline/07-founded.mp4',
    credit: 'The Second Half, a film in production by UNTOLD | 2025',
  },
  {
    date: 'September 14, 2025',
    title: 'First Match',
    description: 'Houston Shine FC plays its first match in the Houston Women\'s Soccer Association fall league.',
    media: '/images/timeline/08-first-match.jpg',
  },
  {
    date: 'October 2025',
    title: 'Nonprofit status',
    description: 'The IRS and the State of Texas recognize Houston Shine FC as a 501(c)(3) organization. The community around the team ramps up fundraising and partnerships to expand programs that support players\' development on and off the field.',
  },
  {
    date: 'January 2026',
    title: 'Scholarships',
    description: 'With funds raised over the holidays, the team sponsors scholarships for six players to enroll in intensive English classes at Houston City College and for two players to advance professional training in dentistry.',
    media: '/images/timeline/11-english-classes.jpeg',
  },
  {
    date: 'Spring 2026',
    title: 'Dynamo Dash Charities',
    description: 'Houston Shine FC begins its second season of competitive play and through a partnership with Dynamo Dash Charities, begins practicing at the training grounds for the Houston Dash.',
    media: '/images/timeline/12-second-season.jpg',
  },
  {
    date: 'March 31, 2026',
    title: 'Women\'s History',
    description: 'Harris County Commissioners Court honors the Shine as part of Women\'s History Month: "through courage, perseverance, and unwavering resolve, Houston Shine FC demonstrates how women\'s athletics can inspire hope and create pathways for opportunity on and off the field."',
    media: '/images/timeline/13-commissioners-court.mp4',
  },
];

// Player data — add real player profiles as they become available
const players: Array<{ name: string; position?: string; bio?: string; photo?: string }> = [
  // Example structure — replace with real player data
  // { name: 'Player Name', position: 'Midfielder', bio: 'Brief bio here.', photo: '/images/players/player-name.jpg' },
];
---

<BaseLayout
  title="Our Story"
  description="From the Afghan women's national team to Houston, Texas — the story of how the Houston Shine FC was born out of evacuation, resettlement, and an unbreakable love of the game."
>
  <!-- ============ PAGE HERO ============ -->
  <section class="story-hero">
    {/* Video background — drop story-hero.mp4 into public/assets/videos/ to activate */}
    <video
      class="story-hero-video"
      autoplay
      loop
      muted
      playsinline
      aria-hidden="true"
    >
      <source src="/assets/videos/story-hero.mp4" type="video/mp4" />
    </video>
    <div class="story-hero-overlay"></div>
    <div class="container story-hero-content" style="max-width: 820px;">
      <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-white); margin-bottom: 1rem;">
        Our Story
      </p>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 1.5rem;">
        Finding our footing, finding our future.
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 680px;">
        Houston Shine is made up of women displaced from their lives in Afghanistan, including players who played in the Afghan Football Federation. This is their story.
      </p>
    </div>
  </section>

  <!-- ============ NARRATIVE INTRO ============ -->
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <p style="font-size: 1.0625rem; line-height: 1.75; color: var(--color-text-secondary);">
        Girls and women in Afghanistan weren't allowed to play soccer until the 2000s. Women and girls who wanted to compete faced huge barriers and societal pressure not to play, but they wouldn't be deterred. When the Taliban came back to power in the summer of 2021, women athletes became targets.
      </p>
      <blockquote class="pull-quote" style="border-left: 3px solid var(--color-gold); padding-left: 1.5rem; margin: 2.5rem 0;">
        "Shine" means reaching for the stars and being a light for other women – blue and white replacing red and black. Sky and hope replacing blood and war.
      </blockquote>
      <p style="font-size: 1.0625rem; line-height: 1.75; color: var(--color-text-secondary);">
        The global football community evacuated multiple waves of women athletes from Afghanistan in 2021. The largest group of Afghan women soccer players in the United States were resettled in Houston in the summer of 2023, without their families or systems of support. Two years later, they started Houston Shine FC to reclaim the joy of soccer and find a team again.
      </p>
    </div>
  </section>

  <!-- ============ VIDEO (placeholder — add Vimeo ID when available) ============ -->
  <!--
  <section class="section section--alt">
    <div class="container" style="max-width: 900px;">
      <SectionHeader label="The Film" heading="The Second Half" subheading="A short documentary following the players' journey from Afghanistan to Houston." />
      <VideoEmbed type="vimeo" src="VIMEO_VIDEO_ID" title="The Second Half — Houston Shine FC Documentary" />
    </div>
  </section>
  -->

  <!-- ============ TIMELINE ============ -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        label="Key Milestones"
        heading="How we got here."
      />
      <div class="timeline-layout">
        <div class="timeline-scroll">
          <Timeline events={milestones} />
        </div>
        <div class="timeline-media-panel">
          <div class="timeline-media-stage">
            {milestones.map((m, i) => (
              m.media ? (
                m.media.endsWith('.mp4') ? (
                  <video
                    data-media-index={i}
                    class="timeline-media-item"
                    loop
                    muted
                    playsinline
                  >
                    <source src={m.media} type="video/mp4" />
                  </video>
                ) : (
                  <img
                    data-media-index={i}
                    class="timeline-media-item"
                    src={m.media}
                    alt={m.title}
                    loading="lazy"
                    decoding="async"
                  />
                )
              ) : null
            ))}
            <button class="timeline-audio-toggle" id="timelineAudioToggle" aria-label="Unmute video">
              <svg class="icon-muted" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
              </svg>
              <svg class="icon-unmuted" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none;">
                <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
              </svg>
            </button>
          </div>
          <div class="timeline-credits">
            {milestones.map((m, i) => (
              m.credit ? (
                <p data-credit-index={i} class="timeline-credit">{m.credit}</p>
              ) : null
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FIFA SECTION ============ -->
  <!-- ============ LEADERSHIP ============ -->
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <SectionHeader
        label="Leadership"
        heading="Houston stepped up."
      />
      <p style="font-size: 1.0625rem; color: var(--color-text-secondary); line-height: 1.65; margin-top: 0; margin-bottom: 3rem;">
        The Shine is powered by women in the Houston soccer community. The team fills a gap in grassroots soccer programming by targeting young adult women and teenage girls who need a boost to get in the game and stick with it. Our volunteers believe in the power of soccer to change lives.
      </p>
      <div class="leadership-grid">
        <div class="leadership-card">
          <div class="leadership-photo-wrap">
            <img
              src="/images/bio/sarah-labowitz.png"
              alt="Sarah Labowitz"
              class="leadership-photo"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="leadership-bio">
            <p class="leadership-title">Advocate and Manager</p>
            <h3 class="leadership-name">Sarah Labowitz</h3>
            <p style="font-size: 0.9375rem; line-height: 1.75; color: var(--color-text-secondary);">
              Sarah Labowitz has spent her career at the intersection of human rights, public policy, and international affairs. A former official at the U.S. State Department and policy director at the ACLU of Texas, she co-founded the NYU Stern Center for Business and Human Rights and is currently a Senior Fellow at the Carnegie Endowment for International Peace. She previously served on the Houston Human Rights Subcommittee for the 2026 FIFA Men's World Cup. In college, Sarah was captain of the Grinnell College women's soccer team and a member of the NCAA's Student Athlete Advisory Committee for Division III. When she met the players who would become the Shine and learned that they didn't have a place to play in their new home, she set out to change that.
            </p>
          </div>
        </div>

        <div class="leadership-card">
          <div class="leadership-photo-wrap">
            <img
              src="/images/bio/rachel-fabre.png"
              alt="Rachel Fabre"
              class="leadership-photo"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="leadership-bio">
            <p class="leadership-title">Head Coach</p>
            <h3 class="leadership-name">Rachel Fabre</h3>
            <p style="font-size: 0.9375rem; line-height: 1.75; color: var(--color-text-secondary);">
              Rachel Fabre played Division I soccer at the University of Texas at Austin, where she was a plaintiff in the Title IX lawsuit that formalized women's sports at the university. She has coached at the collegiate, youth, and high school level, starting her career as the founding coach of the Stephen F. Austin University women's varsity team. Since 2006, she has coached soccer and cross country at St. John's School, where she is known for a whole-athlete approach to developing players. Rachel is passionate about increasing women and girls' access to soccer at all levels, and about developing the game so that it supports women's physical, mental, and emotional health.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PLAYER PROFILES ============ -->
  {players.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <SectionHeader
          label="The Team"
          heading="Meet the Shine."
          subheading="Professional athletes. Emerging leaders. Meet the players building something new."
        />
        <div class="players-grid">
          {players.map(player => (
            <PlayerCard
              name={player.name}
              position={player.position}
              bio={player.bio}
              photo={player.photo}
              class="scroll-reveal-item"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============ CTA ============ -->
  <section style="background-color: var(--color-navy); padding: 4rem 0 2.5rem;">
    <div class="container" style="text-align: center;">
      <h2 style="color: var(--color-white); margin-bottom: 2rem;">Ready to get behind the Shine?</h2>
      <CTAButton href="/support" variant="primary">Support the Shine</CTAButton>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Story Hero ── */
  .story-hero {
    position: relative;
    background-color: var(--color-warm-white);
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .story-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .story-hero-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(255, 255, 255, 0.70);
    z-index: 1;
  }

  .story-hero-content {
    position: relative;
    z-index: 2;
  }

  /* ── Timeline two-column layout ── */
  .timeline-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .timeline-media-panel {
    position: sticky;
    top: 6rem;
  }

  .timeline-media-stage {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-card);
    overflow: hidden;
    background-color: var(--color-navy);
  }

  .timeline-media-item {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .timeline-media-item.active {
    opacity: 1;
  }

  .timeline-audio-toggle {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    z-index: 10;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .timeline-audio-toggle:hover {
    background: rgba(0, 0, 0, 0.75);
  }

  .timeline-credits {
    min-height: 1.5rem;
    margin-top: 0.5rem;
    text-align: right;
  }

  .timeline-credit {
    display: none;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
    margin: 0;
  }

  .timeline-credit.active {
    display: block;
  }

  @media (max-width: 900px) {
    .timeline-layout {
      grid-template-columns: 1fr;
    }
    .timeline-media-panel {
      display: none;
    }
  }

  /* ── Leadership ── */
  .leadership-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .leadership-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .leadership-photo-wrap {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-card);
    overflow: hidden;
    background-color: var(--color-warm-white);
  }

  .leadership-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .leadership-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 0.25rem;
  }

  .leadership-name {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  @media (max-width: 768px) {
    .leadership-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .leadership-photo-wrap {
      aspect-ratio: 3 / 2;
    }
  }

  /* ── Players grid ── */
  .players-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }
</style>

<script>
  const timelineItems = document.querySelectorAll<HTMLElement>('[data-timeline-index]');
  const mediaItems = document.querySelectorAll<HTMLElement>('[data-media-index]');
  const creditItems = document.querySelectorAll<HTMLElement>('[data-credit-index]');
  const audioToggle = document.getElementById('timelineAudioToggle') as HTMLButtonElement | null;

  let isMuted = true;

  function updateToggleUI() {
    if (!audioToggle) return;
    const iconMuted = audioToggle.querySelector('.icon-muted') as HTMLElement;
    const iconUnmuted = audioToggle.querySelector('.icon-unmuted') as HTMLElement;
    iconMuted.style.display = isMuted ? '' : 'none';
    iconUnmuted.style.display = isMuted ? 'none' : '';
    audioToggle.setAttribute('aria-label', isMuted ? 'Unmute video' : 'Mute video');
  }

  if (timelineItems.length && mediaItems.length) {
    function setActiveMedia(timelineIndex: number) {
      let activeEl: HTMLElement | null = null;
      mediaItems.forEach(el => {
        if (parseInt(el.dataset.mediaIndex!) <= timelineIndex) activeEl = el;
      });
      if (!activeEl) activeEl = mediaItems[0] as HTMLElement;

      mediaItems.forEach(el => {
        const wasActive = el.classList.contains('active');
        el.classList.remove('active');
        if (wasActive && el.tagName === 'VIDEO') (el as HTMLVideoElement).pause();
      });

      activeEl.classList.add('active');
      if (activeEl.tagName === 'VIDEO') {
        const vid = activeEl as HTMLVideoElement;
        vid.muted = isMuted;
        vid.play().catch(() => {});
      }

      // Show/hide toggle button — only when active item is a video
      if (audioToggle) {
        audioToggle.style.display = activeEl.tagName === 'VIDEO' ? '' : 'none';
      }

      // Swap credit
      const activeMediaIndex = parseInt(activeEl.dataset.mediaIndex!);
      creditItems.forEach(el => {
        el.classList.toggle('active', parseInt(el.dataset.creditIndex!) === activeMediaIndex);
      });
    }

    // Audio toggle click
    audioToggle?.addEventListener('click', () => {
      isMuted = !isMuted;
      updateToggleUI();
      const activeVideo = document.querySelector<HTMLVideoElement>('[data-media-index].active');
      if (activeVideo) {
        activeVideo.muted = isMuted;
        activeVideo.play().catch(() => {});
      }
    });

    // Start with first item
    setActiveMedia(0);
    updateToggleUI();

    // Hover
    timelineItems.forEach((item, index) => {
      item.addEventListener('mouseenter', () => setActiveMedia(index));
    });

    // Scroll
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setActiveMedia(parseInt((entry.target as HTMLElement).dataset.timelineIndex!));
        }
      });
    }, { threshold: 0.5, rootMargin: '-10% 0px -40% 0px' });

    timelineItems.forEach(item => observer.observe(item));
  }
</script>
