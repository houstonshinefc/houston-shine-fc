---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Timeline from '../components/Timeline.astro';
import PlayerCard from '../components/PlayerCard.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import CTAButton from '../components/CTAButton.astro';

// Timeline data — update dates, titles, and descriptions as the story develops
const milestones = [
  {
    date: '2007–2021',
    title: 'Establishment of the Afghan Women\'s National Football program',
    description: 'Beginning in 2007, Afghanistan establishes a national football program that provides an avenue into sports for women and girls that was previously nonexistent. In 2010, the team plays its first official FIFA sanctioned match, resulting in the expansion of its program, including youth development. In the years that followed, several of the women now on the Houston Shine begin their journey into the sport.',
  },
  {
    date: 'August 2021',
    title: 'Taliban takeover of Afghanistan',
    description: 'The Taliban seizes control of Afghanistan. Women\'s sports are outlawed and by August, there are reports of women athletes being executed.',
  },
  {
    date: 'August–October 2021',
    title: 'Evacuation',
    description: 'Players and their families are evacuated by way of three flights organized by the international human rights community and FIFA. The first two include players and their families who are resettled in Europe and Australia. The third flight, which departs amidst increased chaos, includes players and officials from the national football program. Those players arrive in Albania where the group would be temporarily housed for 18 months while seeking more permanent resettlement.',
  },
  {
    date: 'June 2023',
    title: 'Resettlement in Houston',
    description: 'Several of the players who had been in Albania are resettled in the U.S. with the largest group ending up in Houston, Texas. Shortly after, they\'re celebrated at a ceremony marking the first convening of the 2026 World Cup host cities focused on human rights. Without their parents for support, the players begin their lives in America. They get jobs and apartments, while also supporting their families back home. They don\'t have access to soccer.',
  },
  {
    date: 'April 2025',
    title: 'Connection',
    description: 'A chance invitation to a Houston Dash game ignites a plan to organize a team for the Houston players.',
  },
  {
    date: 'May 9, 2025',
    title: 'Afghan Women\'s Refugee Team',
    description: 'FIFA approves the creation of the Afghan Women\'s Refugee Team. Plans are made to hold camps for resettled players across the globe for a chance to be included on the team. It is deemed unsafe for the U.S. women to have a camp and to be included in the formation of the team.',
  },
  {
    date: 'May 18, 2025',
    title: 'Houston Shine FC is founded',
    description: 'After nearly two years of being off the pitch, community volunteers and Harris County Commissioner Leslie Briones organize a first practice. That evening, the group decides to form the Houston Shine FC, representing hope and the promise of a new beginning. The team includes women from the local Afghan community, including teenagers who had never had access to playing sports.',
  },
  {
    date: 'September 14, 2025',
    title: 'First Match',
    description: 'Houston Shine FC plays its first match in the Houston Women\'s Soccer Association (HWSA) league.',
  },
  {
    date: 'October 2025',
    title: 'Nonprofit is formed',
    description: 'The community around the team establishes Houston Shine FC as a 501(c)(3) organization. Efforts are immediately increased to provide support on and off the field. A mentorship program is established connecting players with women throughout the community.',
  },
  {
    date: 'December 2025',
    title: 'Community',
    description: 'After their first successful season with the HWSA, the players and the community that has formed around them come together for a joyful celebration at St. John\'s School, where Coach Rachel has coached women\'s soccer for 20 years.',
  },
  {
    date: 'January 2026',
    title: 'English Classes',
    description: 'The team enrolls six of the players in Houston Community College for English classes.',
  },
  {
    date: 'March 31, 2026',
    title: 'Recognition by County Commissioners',
    description: 'The Harris County Commissioners Court honors the Houston Shine FC as part of Women\'s History Month.',
  },
];

// Player data — add real player profiles as they become available
const players: Array<{ name: string; position?: string; bio?: string; photo?: string }> = [
  // Example structure — replace with real player data
  // { name: 'Player Name', position: 'Midfielder', bio: 'Brief bio here.', photo: '/images/players/player-name.jpg' },
];
---

<BaseLayout
  title="Our Story"
  description="From the Afghan women's national team to Houston, Texas — the story of how the Houston Shine FC was born out of evacuation, resettlement, and an unbreakable love of the game."
>
  <!-- ============ PAGE HERO ============ -->
  <section style="background-color: var(--color-warm-white); padding: 5rem 0 4rem;">
    <div class="container" style="max-width: 820px;">
      <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-gold); margin-bottom: 1rem;">
        Our Story
      </p>
      <h1 style="font-size: clamp(2.25rem, 6vw, 3.5rem); letter-spacing: -0.03em; margin-bottom: 1.5rem;">
        Finding our footing, finding our future.
      </h1>
      <p style="font-size: 1.125rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 680px;">
        The Houston Shine is made up of women displaced from their lives in Afghanistan, including members of the Afghan women's national football team. This is the story of how they found each other, built community and learned to thrive in Houston, Texas.
      </p>
    </div>
  </section>

  <!-- ============ NARRATIVE INTRO ============ -->
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <p style="font-size: 1.0625rem; line-height: 1.75; color: var(--color-text-secondary);">
        Before August 2021, a pipeline had been established to develop female athletes who would represent their country on an international stage. The Taliban's return to power changed everything overnight. With their futures as athletes and their safety, suddenly at risk, many were evacuated in the chaos surrounding Kabul's fall.
      </p>
      <blockquote class="pull-quote" style="border-left: 3px solid var(--color-gold); padding-left: 1.5rem; margin: 2.5rem 0;">
        "Shine" means reaching for the stars and being a light for other women. Blue and white replacing red and black. Sky and hope replacing blood and war.
      </blockquote>
      <p style="font-size: 1.0625rem; line-height: 1.75; color: var(--color-text-secondary);">
        In 2023, several players landed in Houston where they had to start new lives without their loved ones or the familiarities of their homeland. Two years later, Houston Shine FC was formed to give these athletes back what once filled them with hope and joy. A place to compete. A place to connect. A place to thrive.
      </p>
    </div>
  </section>

  <!-- ============ VIDEO (placeholder — add Vimeo ID when available) ============ -->
  <!--
  <section class="section section--alt">
    <div class="container" style="max-width: 900px;">
      <SectionHeader label="The Film" heading="The Second Half" subheading="A short documentary following the players' journey from Afghanistan to Houston." />
      <VideoEmbed type="vimeo" src="VIMEO_VIDEO_ID" title="The Second Half — Houston Shine FC Documentary" />
    </div>
  </section>
  -->

  <!-- ============ TIMELINE ============ -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        label="Key Milestones"
        heading="How we got here."
      />
      <div style="max-width: 680px;">
        <Timeline events={milestones} />
      </div>
    </div>
  </section>

  <!-- ============ FIFA SECTION ============ -->
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <SectionHeader
        label="The Bigger Picture"
        heading="When FIFA fell short, Houston stepped up."
      />
      <p style="font-size: 1.0625rem; line-height: 1.75; color: var(--color-text-secondary); margin-bottom: 1.5rem;">
        FIFA created an Afghanistan women's refugee team, but excluded the US-based players. The Shine's athletes found themselves locked out of the only international pathway available to refugee footballers, not by lack of skill or commitment, but by geography and bureaucracy.
      </p>
      <p style="font-size: 1.0625rem; line-height: 1.75; color: var(--color-text-secondary);">
        Where FIFA drew a line, Houston's soccer community drew a different one. The Houston Dash, the Houston Dynamo FC, the HWSA, Commissioner Leslie Briones, and a growing network of civic and community partners have all stepped in to create the infrastructure of support that international bodies failed to provide.
      </p>
    </div>
  </section>

  <!-- ============ PLAYER PROFILES ============ -->
  {players.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <SectionHeader
          label="The Team"
          heading="Meet the Shine."
          subheading="Professional athletes. Emerging leaders. Meet the players building something new."
        />
        <div class="players-grid">
          {players.map(player => (
            <PlayerCard
              name={player.name}
              position={player.position}
              bio={player.bio}
              photo={player.photo}
              class="scroll-reveal-item"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============ CTA ============ -->
  <section style="background-color: var(--color-navy); padding: 4rem 0;">
    <div class="container" style="text-align: center;">
      <h2 style="color: var(--color-white); margin-bottom: 1rem;">Be part of what's next.</h2>
      <p style="color: rgba(255,255,255,0.7); max-width: 480px; margin: 0 auto 2rem;">
        The Shine is building something real, on the pitch and beyond it. Your support makes it possible.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <CTAButton href="/support" variant="primary">Support the Shine</CTAButton>
        <CTAButton href="/programs" variant="outline-white">See Our Programs</CTAButton>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .players-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }
</style>
