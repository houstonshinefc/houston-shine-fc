---
interface TimelineEvent {
  date: string;
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  media?: string;
  credit?: string;
}

interface Props {
  events: TimelineEvent[];
}

const { events } = Astro.props;
---

<div class="timeline" role="list">
  {events.map((event, index) => (
    <div class="timeline-item scroll-reveal-item" role="listitem" data-timeline-index={index}>
      <p class="timeline-date">{event.date}</p>
      <h3 style="font-size: 1.0625rem; margin-bottom: 0.5rem;">{event.title}</h3>
      <p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.65; margin: 0;">
        {event.description}
      </p>
      {event.image && (
        <img
          src={event.image}
          alt={event.imageAlt ?? event.title}
          style="margin-top: 1rem; border-radius: 8px; width: 100%; max-width: 480px; object-fit: cover;"
          loading="lazy"
          decoding="async"
        />
      )}
      {event.media && (
        <div class="timeline-inline-media">
          {event.media.endsWith('.mp4') ? (
            <video autoplay loop muted playsinline class="timeline-inline-media-el">
              <source src={event.media} type="video/mp4" />
            </video>
          ) : (
            <img
              src={event.media}
              alt={event.title}
              class="timeline-inline-media-el"
              loading="lazy"
              decoding="async"
            />
          )}
          {event.credit && (
            <p class="timeline-inline-credit">{event.credit}</p>
          )}
        </div>
      )}
    </div>
  ))}
  <div class="timeline-continues" aria-label="More to come">
    <span></span>
    <span></span>
    <span></span>
  </div>
</div>

<style>
  .timeline-inline-media {
    display: none;
    margin-top: 1rem;
  }

  .timeline-inline-media-el {
    width: 100%;
    border-radius: 8px;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .timeline-inline-credit {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-align: right;
    margin: 0.375rem 0 0;
  }

  @media (max-width: 900px) {
    .timeline-inline-media {
      display: block;
    }
  }

  .timeline-continues {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 5px;
    margin-left: -2rem;
    margin-top: 0.5rem;
  }

  .timeline-continues span {
    display: block;
    width: 2px;
    height: 6px;
    background-color: var(--color-gold);
    opacity: 0.5;
    border-radius: 1px;
  }

  .timeline-continues span:nth-child(2) {
    opacity: 0.35;
  }

  .timeline-continues span:nth-child(3) {
    opacity: 0.2;
  }
</style>
