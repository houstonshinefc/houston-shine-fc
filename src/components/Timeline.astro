---
interface TimelineEvent {
  date: string;
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  media?: string;
  credit?: string;
}

interface Props {
  events: TimelineEvent[];
}

const { events } = Astro.props;
---

<div class="timeline" role="list">
  {events.map((event, index) => (
    <div class="timeline-item scroll-reveal-item" role="listitem" data-timeline-index={index}>
      <p class="timeline-date">{event.date}</p>
      <h3 style="font-size: 1.0625rem; margin-bottom: 0.5rem;">{event.title}</h3>
      <p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.65; margin: 0;">
        {event.description}
      </p>
      {event.image && (
        <img
          src={event.image}
          alt={event.imageAlt ?? event.title}
          style="margin-top: 1rem; border-radius: 8px; width: 100%; max-width: 480px; object-fit: cover;"
          loading="lazy"
          decoding="async"
        />
      )}
      {event.media && (
        <div class="timeline-inline-media">
          {event.media.endsWith('.mp4') ? (
            <div class="timeline-inline-video-wrap">
              <video autoplay loop muted playsinline class="timeline-inline-media-el timeline-inline-video">
                <source src={event.media} type="video/mp4" />
              </video>
              <button class="timeline-inline-audio-toggle" aria-label="Unmute video">
                <svg class="icon-muted" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
                </svg>
                <svg class="icon-unmuted" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none;">
                  <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
                </svg>
              </button>
            </div>
          ) : (
            <img
              src={event.media}
              alt={event.title}
              class="timeline-inline-media-el"
              loading="lazy"
              decoding="async"
            />
          )}
          {event.credit && (
            <p class="timeline-inline-credit">{event.credit}</p>
          )}
        </div>
      )}
    </div>
  ))}
  <div class="timeline-continues" aria-label="More to come">
    <span></span>
    <span></span>
    <span></span>
  </div>
</div>

<style>
  .timeline-inline-media {
    display: none;
    margin-top: 1rem;
  }

  .timeline-inline-media-el {
    width: 100%;
    border-radius: 8px;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .timeline-inline-video-wrap {
    position: relative;
    display: block;
  }

  .timeline-inline-audio-toggle {
    position: absolute;
    bottom: 0.5rem;
    right: 0.5rem;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .timeline-inline-audio-toggle:hover {
    background: rgba(0, 0, 0, 0.75);
  }

  .timeline-inline-credit {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-align: right;
    margin: 0.375rem 0 0;
  }

  @media (max-width: 900px) {
    .timeline-inline-media {
      display: block;
    }
  }

  .timeline-continues {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 5px;
    margin-left: -2rem;
    margin-top: 0.5rem;
  }

  .timeline-continues span {
    display: block;
    width: 2px;
    height: 6px;
    background-color: var(--color-gold);
    opacity: 0.5;
    border-radius: 1px;
  }

  .timeline-continues span:nth-child(2) {
    opacity: 0.35;
  }

  .timeline-continues span:nth-child(3) {
    opacity: 0.2;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.timeline-inline-audio-toggle').forEach(btn => {
    const wrap = btn.closest('.timeline-inline-video-wrap');
    const video = wrap?.querySelector<HTMLVideoElement>('video');
    if (!video) return;

    btn.addEventListener('click', () => {
      video.muted = !video.muted;
      video.play().catch(() => {});
      const iconMuted = btn.querySelector<HTMLElement>('.icon-muted')!;
      const iconUnmuted = btn.querySelector<HTMLElement>('.icon-unmuted')!;
      iconMuted.style.display = video.muted ? '' : 'none';
      iconUnmuted.style.display = video.muted ? 'none' : '';
      btn.setAttribute('aria-label', video.muted ? 'Unmute video' : 'Mute video');
    });
  });
</script>
