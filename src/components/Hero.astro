---
interface Props {
  heading: string;
  subheading?: string;
  image?: string;
  imageAlt?: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const {
  heading,
  subheading,
  image,
  imageAlt = '',
  primaryCTA,
  secondaryCTA,
} = Astro.props;
---

<section class={`hero ${image ? 'hero--fullbleed' : ''}`}>
  {image && (
    <img
      src={image}
      alt={imageAlt}
      class="hero-bg"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  )}
  <div class="container hero-inner">
    <div class="hero-content">
      <h1 class="hero-heading">{heading}</h1>
      {subheading && (
        <p class="hero-subheading">{subheading}</p>
      )}
      {(primaryCTA || secondaryCTA) && (
        <div class="hero-ctas">
          {primaryCTA && (
            <a href={primaryCTA.href} class="btn btn-primary">{primaryCTA.label}</a>
          )}
          {secondaryCTA && (
            <a href={secondaryCTA.href} class="btn btn-outline-white-filled">{secondaryCTA.label}</a>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--color-white);
    overflow: hidden;
  }

  /* Full-bleed layout */
  .hero--fullbleed {
    min-height: 80vh;
    display: flex;
    align-items: flex-start;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    z-index: 0;
  }


  .hero-inner {
    position: relative;
    z-index: 2;
    padding-top: 3.75rem;
    padding-bottom: 5rem;
    width: 100%;
  }

  .hero-content {
    max-width: 680px;
  }

  .hero-heading {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    color: var(--color-navy);
  }

  .hero-title {
    display: block;
    font-style: italic;
    letter-spacing: 0.02em;
  }

  .hero-subheading {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    max-width: 520px;
    margin-bottom: 2rem;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero--fullbleed {
      min-height: 60vh;
    }

    .hero-inner {
      padding-top: 2.625rem;
    }

    .hero-heading {
      font-size: clamp(1.875rem, 8vw, 2.5rem);
    }

    .hero-ctas {
      display: none;
    }
  }
</style>
