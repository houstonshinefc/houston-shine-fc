---
interface Props {
  heading: string;
  subheading?: string;
  image?: string;
  mobileImage?: string;
  mobileFullHeight?: boolean;
  imageAlt?: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
  figures?: string[];
  figureBackground?: string;
}

const {
  heading,
  subheading,
  image,
  mobileImage,
  mobileFullHeight = false,
  imageAlt = '',
  primaryCTA,
  secondaryCTA,
  figures,
  figureBackground,
} = Astro.props;

const hasAnimatedHero = figures && figures.length > 0 && figureBackground;
---

<section class={`hero ${image || hasAnimatedHero ? 'hero--fullbleed' : ''} ${mobileFullHeight ? 'hero--mobile-full' : ''}`}>
  {/* Static hero image — always rendered. On mobile shows mobile image. On desktop acts as fallback if figures fail. */}
  {image && (
    <picture>
      {mobileImage && (
        <source srcset={mobileImage} media="(max-width: 768px)" />
      )}
      <img
        src={image}
        alt={imageAlt}
        class="hero-bg"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </picture>
  )}
  {/* Animated desktop figure layers */}
  {hasAnimatedHero && (
    <div class="hero-figures-layer" aria-hidden="true">
      <img src={figureBackground} class="hero-figure-base" alt="" loading="eager" fetchpriority="high" decoding="async" />
      {figures.map((fig, i) => (
        <img
          src={fig}
          class="hero-figure"
          style={`--i: ${i}`}
          alt=""
          loading="eager"
          decoding="async"
        />
      ))}
    </div>
  )}
  <div class="container hero-inner">
    <div class="hero-content">
      <h1 class="hero-heading">{heading}</h1>
      {subheading && (
        <p class="hero-subheading">{subheading}</p>
      )}
      {(primaryCTA || secondaryCTA) && (
        <div class="hero-ctas">
          {primaryCTA && (
            <a href={primaryCTA.href} class="btn btn-primary">{primaryCTA.label}</a>
          )}
          {secondaryCTA && (
            <a href={secondaryCTA.href} class="btn btn-outline-white-filled">{secondaryCTA.label}</a>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--color-white);
    overflow: hidden;
  }

  /* Full-bleed layout */
  .hero--fullbleed {
    min-height: 80vh;
    display: flex;
    align-items: flex-start;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    z-index: 0;
  }

  /* ── Animated figure layers (desktop only) ── */
  .hero-figures-layer {
    display: none; /* hidden on mobile — static image shows instead */
    position: absolute;
    inset: 0;
    z-index: 1; /* sits above static hero-bg, which acts as fallback */
  }

  .hero-figure-base,
  .hero-figure {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
  }

  .hero-figure {
    will-change: transform;
  }

  @media (min-width: 769px) {
    .hero-figures-layer {
      display: block;
    }
  }


  .hero-inner {
    position: relative;
    z-index: 2;
    padding-top: 3.75rem;
    padding-bottom: 5rem;
    width: 100%;
  }

  .hero-content {
    max-width: 680px;
  }

  .hero-heading {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    color: var(--color-navy);
  }


  .hero-subheading {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    max-width: 520px;
    margin-bottom: 2rem;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-ctas .btn {
    opacity: 0.95;
  }

  .hero-ctas .btn:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .hero--fullbleed {
      min-height: 60vh;
    }

    .hero-inner {
      padding-top: 2.625rem;
    }

    .hero-heading {
      font-size: clamp(1.875rem, 8vw, 2.5rem);
      margin-bottom: 0.625rem;
    }

    .hero-ctas {
      display: none;
    }

    /* Full-height mobile variant — image sets the section height */
    .hero--mobile-full {
      min-height: unset;
      display: block;
    }

    .hero--mobile-full picture {
      display: block;
    }

    .hero--mobile-full .hero-bg {
      position: relative;
      inset: auto;
      width: 100%;
      height: auto;
      object-fit: unset;
    }

    .hero--mobile-full .hero-inner {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
    }
  }
</style>

{hasAnimatedHero && (
  <script>
    (function () {
      const hero = document.querySelector('.hero');
      if (!hero) return;

      const figures = Array.from(hero.querySelectorAll('.hero-figure'));
      if (!figures.length) return;

      if (window.matchMedia('(max-width: 768px)').matches) return;

      let rafPending = false;

      function onScroll() {
        if (rafPending) return;
        rafPending = true;
        requestAnimationFrame(() => {
          rafPending = false;
          const scrollY = window.scrollY;
          const heroHeight = hero.offsetHeight;

          const progress = scrollY / heroHeight; // 0 → 1 as hero scrolls out
          const threshold = 0.4; // start rising in the last 60% of the hero

          if (progress < threshold) {
            figures.forEach(fig => fig.style.transform = 'translateY(0px)');
            return;
          }

          const relativeProgress = (progress - threshold) / (1 - threshold); // 0 → 1
          const translateY = -(relativeProgress * 30);
          figures.forEach(fig => {
            fig.style.transform = `translateY(${translateY}px)`;
          });
        });
      }

      window.addEventListener('scroll', onScroll, { passive: true });
    })();
  </script>
)}
