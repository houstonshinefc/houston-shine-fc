---
interface Props {
  href: string;
  variant?: 'primary' | 'outline' | 'outline-white';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  class: className = '',
} = Astro.props;

const variantClass = {
  primary: 'btn-primary',
  outline: 'btn-outline',
  'outline-white': 'btn-outline-white',
}[variant];

const sizeStyle = {
  sm: 'font-size: 0.8125rem; padding: 0.5rem 1.25rem;',
  md: '',
  lg: 'font-size: 1rem; padding: 0.875rem 2.25rem;',
}[size];
---

<a
  href={href}
  class={`btn ${variantClass} ${className}`}
  style={sizeStyle}
  {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <slot />
</a>
