---
interface Props {
  publication: string;
  headline: string;
  date: string;
  excerpt?: string;
  url: string;
  logo?: string;
}

const { publication, headline, date, excerpt, url, logo } = Astro.props;
---

<article class="card press-card">
  <a href={url} target="_blank" rel="noopener noreferrer" class="press-card-link" aria-label={`${headline} — ${publication}`}>
    <div class="press-card-header">
      {logo ? (
        <img src={logo} alt={publication} class="press-logo" height="24" loading="lazy" />
      ) : (
        <span class="press-pub-name">{publication}</span>
      )}
      <time datetime={date} class="press-date">
        {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </div>
    <h3 class="press-headline">{headline}</h3>
    {excerpt && <p class="press-excerpt">{excerpt}</p>}
    <span class="press-read-more" aria-hidden="true">Read story →</span>
  </a>
</article>

<style>
  .press-card-link {
    display: block;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .press-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.875rem;
  }

  .press-logo {
    height: 24px;
    width: auto;
    object-fit: contain;
    object-position: left;
    filter: grayscale(100%) brightness(0);
    opacity: 0.45;
    transition: opacity 0.2s;
  }

  .press-card:hover .press-logo {
    opacity: 0.75;
  }

  .press-pub-name {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .press-date {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .press-headline {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 0.625rem;
    letter-spacing: -0.01em;
    transition: color 0.2s;
  }

  .press-card:hover .press-headline {
    color: var(--color-gold);
  }

  .press-excerpt {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .press-read-more {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-gold);
    letter-spacing: 0.01em;
  }
</style>
