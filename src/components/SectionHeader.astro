---
interface Props {
  label?: string;      // Small uppercase label above the heading
  heading: string;
  subheading?: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  label,
  heading,
  subheading,
  align = 'left',
  class: className = '',
} = Astro.props;

const alignStyle = align === 'center' ? 'text-align: center; max-width: 680px; margin-left: auto; margin-right: auto;' : '';
---

<div class={`section-header ${className}`} style={alignStyle}>
  {label && (
    <p class="section-label">{label}</p>
  )}
  <h2>{heading}</h2>
  {subheading && (
    <p class="section-subheading">{subheading}</p>
  )}
</div>

<style>
  .section-header {
    margin-bottom: 2rem;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.5rem;
  }

  .section-subheading {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    margin-top: 0.75rem;
    line-height: 1.65;
    max-width: 640px;
  }
</style>
